<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.notion-operations-meeting</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/node</string>
    <string>/path/to/notion-slack-automation/jobs/operations-meeting-copy/index.mjs</string>
    <string>--apply</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/path/to/notion-slack-automation</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>12</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/path/to/notion-slack-automation/logs/notion-operations-meeting.out.log</string>

  <key>StandardErrorPath</key>
  <string>/path/to/notion-slack-automation/logs/notion-operations-meeting.err.log</string>
</dict>
</plist>
